extends layout
block content 
  .container.min-vh-100.d-flex.justify-content-center.align-items-center
    .card.shadow-lg.border-0.rounded-4(style='width: 100%; max-width: 450px;')
      .card-body.p-5
        h2.text-center.fw-bold.mb-2 Batteries
        p.text-center.text-muted.mb-4 Please enter your details to sign in.
        form(method='post' action='/registerBattery' enctype="multipart/form-data")
          .mb-3
            label.form-label.fw-semibold(for='') Battery Type
            select#batteryType(name="batteryType")
              option(value="") Select tire type
              option(value="Absorbent Glass Matt") Absorbent Glass Matt
              option(value="Flooded") Flooded
              option(value="Lithium-ion") Lithium-ion
          .mb-4
            label.form-label.fw-semibold(for='') Battery Size
            select#batterySize(name="batterySize")
              option(value="") Select battery size
              option(value="12V") 12V(for bodabodas, small cars)
              option(value="24V") 24V(for big trucks)
          .mb-4
            label.form-label.fw-semibold(for='batteryImage') Battery Image
            input#batteryImage.form-control(type='file' placeholder='' name='batteryImage')
          button.btn.btn-primary.w-100.py-2.fw-bold.rounded-3(type='submit') Add Battery
  script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js')
