extends layout 
block content
  .row.g-4.mb-4
    .col-md-4
      .card.shadow.dashboard-card.p-3.text-center
        h5 PARKEASE DAILY REPORTS
        h2.text-primary 120
    .col-md-4
      .card.shadow.dashboard-card.p-3.text-center
        h5 REVENUE OVERVIEW
        h2.text-danger UGX 4,600,000
    .col-md-4
      .card.shadow.dashboard-card.p-3.text-center
        h5 Today&apos;s Revenue
        h2.text-success UGX 450,000
  // Parking Activity Table
  .card.shadow.mb-4
    .card-body
      h5.mb-3 Recent Parking Activity
      table.table
        thead
          tr
            th(scope='col') RECEIPT#
            th(scope='col') PLATE#
            th(scope='col') IN-TIME
            th(scope='col') OUT-TIME
            th(scope='col') DURATION
            th(scope='col') FEE
        tbody
          tr
            td #PE-98231
            td UAA 214A
            td 08:15 AM
            td 05:30 PM
            td 9h 15m
            td UGX 25,000
          tr
            td #PE-98232
            td UBB 673B
            td 09:00 AM
            td 02:15 PM
            td 5h 15m
            td UGX 15,000
          tr
            td #PE-98233
            td UAX 982X
            td 10:30 AM
            td 06:45 PM
            td 8h 15m
            td UGX 22,000
      .col-md-4
        .card.shadow.dashboard-card.p-3.text-center
          span DAILY GRAND TOTAL :
          h2 UGX 6,790,000
      footer.footer
        p ADMIN CONTROL PANEL
        p &copy; 2026 ParkEase Smart Systems
