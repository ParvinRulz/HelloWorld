extends layout
block content 
  .container.min-vh-100.d-flex.justify-content-center.align-items-center
    .card.shadow-lg.border-0.rounded-4(style='width: 100%; max-width: 450px;')
      .card-body.p-5
        h2.text-center.fw-bold.mb-2 Welcome Back
        p.text-center.text-muted.mb-4 Please enter your details to sign in.
        form(method='post' action='')
          .mb-3
            label.form-label.fw-semibold(for='tireType') Tire Type
            input#email.form-control(type='text' name='tireType') Tire Type
            select#tireType(name="tireType")
            option(value="") Select tire type
            option(value="Bridgestone") Bridgestone
            option(value="goodyear") Goodyear
            option(value="CEAT") CEAT
            option(value="continental") Continental
          .mb-4
            label.form-label.fw-semibold(for='tireSize') Tire Size
            select#tireSize(name="tireSize")
            option(value="") Select tire size
            option(value="15 inch")
            option(value="16 inch")
            option(value="17 inch")
            option(value="18 inch")
          .mb-4
            label.form-label.fw-semibold(for='tirePrice') Tire Price
        select#tireService(name="tireService")
            option(value="") Select tire service
          option(value="pressure")
          option(value="puncture-fixing")
          option(value="valves")
        button.btn.btn-primary.w-100.py-2.fw-bold.rounded-3(type='submit') Log In
          .text-center.mt-4
            p.mb-0.text-muted
              | Don&apos;t have an account? 
              a.text-decoration-none.fw-semibold(href='/auth/signup') Sign up
  script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js')
